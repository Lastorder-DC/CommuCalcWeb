# 서버 포트
PORT=3000

# MySQL 데이터베이스 설정
DB_HOST=localhost
DB_PORT=3306
DB_USER=commucalc
DB_PASSWORD=your_password_here
DB_NAME=commucalc

# JWT 비밀 키 (반드시 변경하세요)
JWT_SECRET=change-this-to-a-random-secret-key

# JWT 토큰 만료 시간
JWT_EXPIRES_IN=7d

# CORS 허용 오리진 (콤마로 구분)
CORS_ORIGIN=http://localhost:5173,https://calc.yumeka.xyz
